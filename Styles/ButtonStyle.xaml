<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="SharedGlowButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#73000000" />
        <Setter Property="BorderBrush" Value="{StaticResource GhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#C1FFFE" />
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource HeadlineFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ButtonFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid SnapsToDevicePixels="True">
                        <Border
                            x:Name="GlowHalo"
                            CornerRadius="{StaticResource ButtonCornerRadius}"
                            BorderBrush="#9900FFFF"
                            BorderThickness="1"
                            Opacity="0">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="16"
                                    ShadowDepth="0"
                                    Color="#4D00FFFF"
                                    Opacity="1" />
                            </Border.Effect>
                        </Border>

                        <Border
                            x:Name="Shell"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ButtonCornerRadius}">
                            <Grid ClipToBounds="True">
                                <Border
                                    Margin="1"
                                    CornerRadius="7"
                                    Background="#12232728"
                                    Opacity="0.9" />
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Shell" Property="Opacity" Value="0.4" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Shell" Property="Background" Value="#1400FFFF" />
                            <Setter TargetName="Shell" Property="BorderBrush" Value="#9900FFFF" />
                            <Setter TargetName="GlowHalo" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Shell" Property="Background" Value="#1E00FFFF" />
                            <Setter TargetName="Shell" Property="BorderBrush" Value="#9900FFFF" />
                            <Setter TargetName="GlowHalo" Property="Opacity" Value="0.7" />
                        </Trigger>
                        <Trigger Property="Tag" Value="True">
                            <Setter TargetName="Shell" Property="BorderBrush" Value="#9900FFFF" />
                            <Setter TargetName="GlowHalo" Property="Opacity" Value="0.8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HudCommandButtonBaseStyle" TargetType="Button" BasedOn="{StaticResource SharedGlowButtonStyle}" />
    <Style x:Key="HudActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SharedGlowButtonStyle}">
        <Setter Property="MinWidth" Value="196" />
        <Setter Property="MinHeight" Value="44" />
    </Style>
    <Style x:Key="HudNavButtonStyle" TargetType="Button" BasedOn="{StaticResource SharedGlowButtonStyle}">
        <Setter Property="MinWidth" Value="128" />
        <Setter Property="MinHeight" Value="40" />
    </Style>
    <Style x:Key="HudNavCapsuleButtonStyle" TargetType="Button" BasedOn="{StaticResource HudNavButtonStyle}" />
    <Style x:Key="HudHeroButtonStyle" TargetType="Button" BasedOn="{StaticResource SharedGlowButtonStyle}">
        <Setter Property="MinWidth" Value="224" />
        <Setter Property="MinHeight" Value="46" />
    </Style>
    <Style x:Key="HudHeroCapsuleButtonStyle" TargetType="Button" BasedOn="{StaticResource HudHeroButtonStyle}" />
    <Style x:Key="HudTileButtonStyle" TargetType="Button" BasedOn="{StaticResource SharedGlowButtonStyle}">
        <Setter Property="MinHeight" Value="44" />
    </Style>
    <Style x:Key="HudLaunchTileButtonStyle" TargetType="Button" BasedOn="{StaticResource HudTileButtonStyle}" />

    <Style x:Key="HudComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="#66151B1A" />
        <Setter Property="BorderBrush" Value="{StaticResource SoftDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
    </Style>

    <Style x:Key="HudLineTextBoxStyle" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{StaticResource SoftDividerBrush}" />
        <Setter Property="Padding" Value="0,0,0,8" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
    </Style>

    <Style x:Key="HudLineDatePickerStyle" TargetType="DatePicker">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{StaticResource SoftDividerBrush}" />
        <Setter Property="Padding" Value="0,0,0,8" />
    </Style>

    <Style x:Key="HudCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            x:Name="Box"
                            Width="12"
                            Height="12"
                            Margin="0,0,10,0"
                            BorderBrush="{StaticResource GhostBorderBrush}"
                            BorderThickness="1"
                            Background="Transparent" />
                        <ContentPresenter VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentCyanBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
