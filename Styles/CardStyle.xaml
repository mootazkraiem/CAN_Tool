<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="HudCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#73000000" />
        <Setter Property="BorderBrush" Value="#5900FFFF" />
        <Setter Property="BorderThickness" Value="{StaticResource PanelBorderThickness}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="HudHeroCardStyle" TargetType="Border" BasedOn="{StaticResource HudCardStyle}">
        <Setter Property="Background" Value="#80000000" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="HudCommandCardStyle" TargetType="Border" BasedOn="{StaticResource HudCardStyle}">
        <Setter Property="Background" Value="#80000000" />
        <Setter Property="BorderBrush" Value="#7300FFFF" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="HudDataPanelStyle" TargetType="Border" BasedOn="{StaticResource HudCardStyle}">
        <Setter Property="Background" Value="#73000000" />
    </Style>

    <Style x:Key="HudStatusCardStyle" TargetType="Border" BasedOn="{StaticResource HudCardStyle}">
        <Setter Property="Padding" Value="18" />
        <Setter Property="BorderBrush" Value="#5900FFFF" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="CRITICAL">
                <Setter Property="BorderBrush" Value="#66FF716C" />
                <Setter Property="Background" Value="#73110608" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="WATCH">
                <Setter Property="BorderBrush" Value="#66F3D15A" />
                <Setter Property="Background" Value="#73140F04" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="GOOD">
                <Setter Property="BorderBrush" Value="#5900FFFF" />
                <Setter Property="Background" Value="#73000000" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="HudEyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource HeadlineFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource HeadlineFontFamily}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudSectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource HeadlineFontFamily}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="HudBodyTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudMutedTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#7AA8ACAB" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudMetricValueTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource HeadlineFontFamily}" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="HudMetricLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource HeadlineFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudBadgeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#1200FFFF" />
        <Setter Property="BorderBrush" Value="#3300FFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
</ResourceDictionary>
