<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="SurfaceColor">#0B0F0F</Color>
    <Color x:Key="SurfaceContainerColor">#151B1A</Color>
    <Color x:Key="SurfaceContainerHighColor">#1B2121</Color>
    <Color x:Key="SurfaceContainerHighestColor">#212727</Color>
    <Color x:Key="AccentCyanColor">#00FFFF</Color>
    <Color x:Key="AccentSecondaryColor">#0DEAFC</Color>
    <Color x:Key="PrimaryTextColor">#FAFDFC</Color>
    <Color x:Key="SecondaryTextColor">#A8ACAB</Color>
    <Color x:Key="ErrorColor">#FF716C</Color>
    <Color x:Key="SuccessColor">#30FFD5</Color>
    <Color x:Key="GlassPanelColor">#99151B1A</Color>
    <Color x:Key="GlassPanelHighColor">#B21B2121</Color>
    <Color x:Key="GlassPanelHighestColor">#C0212727</Color>
    <Color x:Key="GhostBorderColor">#5900FFFF</Color>
    <Color x:Key="GhostBorderStrongColor">#8000FFFF</Color>
    <Color x:Key="SoftDividerColor">#33454948</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource GlassPanelColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="{StaticResource GlassPanelHighColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighestBrush" Color="{StaticResource GlassPanelHighestColor}" />
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyanColor}" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondaryColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="GhostBorderBrush" Color="{StaticResource GhostBorderColor}" />
    <SolidColorBrush x:Key="GhostBorderStrongBrush" Color="{StaticResource GhostBorderStrongColor}" />
    <SolidColorBrush x:Key="SoftDividerBrush" Color="{StaticResource SoftDividerColor}" />

    <FontFamily x:Key="HeadlineFontFamily">Space Grotesk</FontFamily>
    <FontFamily x:Key="BodyFontFamily">Manrope</FontFamily>

    <CornerRadius x:Key="ButtonCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">16</CornerRadius>
    <Thickness x:Key="PanelBorderThickness">1</Thickness>
    <Thickness x:Key="ButtonPadding">18,8</Thickness>

    <sys:Double x:Key="ButtonFontSize">12.5</sys:Double>
    <sys:Double x:Key="LabelTrackingSize">11</sys:Double>
    <sys:Double x:Key="GlassBlurRadius">14</sys:Double>
</ResourceDictionary>
