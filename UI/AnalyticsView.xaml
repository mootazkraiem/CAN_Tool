<UserControl
    x:Class="CANvision.Native.UI.AnalyticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:CANvision.Native.ViewModels">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://siteoforigin:,,,/assets/6k+-D+copy+-+High+Contrast.webp" Stretch="UniformToFill" Opacity="0.24" />
        </Grid.Background>
        <Rectangle Fill="#E0080C0F" />

        <Grid>
            <!-- Calibration Overlay -->
            <Border Background="#F0080C0F" Visibility="{Binding IsCalibrating, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Visible}" Panel.ZIndex="1000">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="WAITING FOR DIAGNOSTIC DATA..." 
                               Foreground="#00ECFF" 
                               FontFamily="{StaticResource HeadlineFontFamily}" 
                               FontSize="24" 
                               TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:1" AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CalibrationText}" Margin="0,10,0,0" Foreground="#597983" FontFamily="Consolas" FontSize="12" TextAlignment="Center" />
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True">
                <Grid Margin="24,20,24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="12" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="10" Text="PRIMARY FILTERS" />
                            <TextBlock Margin="0,14,0,0" Foreground="#597983" FontFamily="Consolas" FontSize="9" Text="DATE RANGE" />
                            <ComboBox Margin="0,4,0,0" Style="{StaticResource HudComboBoxStyle}" SelectedIndex="0">
                                <ComboBoxItem Content="Last 30 Days" />
                            </ComboBox>
                            
                            <TextBlock Margin="0,14,0,0" Foreground="#597983" FontFamily="Consolas" FontSize="9" Text="CATEGORY" />
                            <StackPanel Margin="0,6,0,0">
                                <Button Style="{StaticResource HudActionButtonStyle}" Command="{Binding OverviewCommand}" Content="OVERVIEW" Margin="0,0,0,6" HorizontalContentAlignment="Left" />
                                <Button Style="{StaticResource HudActionButtonStyle}" Command="{Binding BatteryDegradationCommand}" Content="BATTERY DEGRADATION" Margin="0,0,0,6" HorizontalContentAlignment="Left" />
                                <Button Style="{StaticResource HudActionButtonStyle}" Command="{Binding FaultTrendsCommand}" Content="FAULT TRENDS" Margin="0,0,0,6" HorizontalContentAlignment="Left" />
                                <Button Style="{StaticResource HudActionButtonStyle}" Command="{Binding AIAnomaliesCommand}" Content="AI ANOMALIES" Margin="0,0,0,6" HorizontalContentAlignment="Left" />
                                <Button Style="{StaticResource HudActionButtonStyle}" Command="{Binding ReliabilityScoreCommand}" Content="RELIABILITY SCORE" Margin="0,0,0,6" HorizontalContentAlignment="Left" />
                            </StackPanel>

                            <Button Margin="0,14,0,0" Style="{StaticResource HudActionButtonStyle}" Command="{Binding GenerateReportCommand}" Content="GENERATE REPORT" />
                            <Button Margin="0,8,0,0" Style="{StaticResource HudActionButtonStyle}" Command="{Binding CompareSessionsCommand}" Content="COMPARE SESSIONS" />

                            <Border Margin="0,18,0,0" Padding="10" Background="#7A0A0E10" BorderBrush="#1E2F363C" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Foreground="#617F88" FontFamily="Consolas" FontSize="9" Text="SYSTEM STATUS" />
                                    <TextBlock Margin="0,4,0,0" Foreground="#D7EDF2" FontFamily="Consolas" FontSize="10" Text="NOMINAL" />
                                    <Rectangle Margin="0,8,0,0" Height="2" Fill="#3ABFD0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="1" Margin="16,0,16,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="250" />
                            <RowDefinition Height="150" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Content Sections using DataTriggers -->
                        <Border Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAnalyticsSection}" Value="OVERVIEW">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedAnalyticsSection}" Value="BATTERY DEGRADATION">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="250" />
                                    <RowDefinition Height="150" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Padding="14" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                                    <Grid>
                                        <DockPanel>
                                            <TextBlock Foreground="#DAEFF3" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Text="BATTERY DEGRADATION TREND" />
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <TextBlock Foreground="#00ECFF" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="40" FontWeight="Bold" Text="{Binding BatteryHealthIndexText}" />
                                            </StackPanel>
                                        </DockPanel>
                                        <ItemsControl Margin="0,48,20,18" VerticalAlignment="Bottom" ItemsSource="{Binding ChartPoints}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,4,0" Background="#301CE3F4" Width="10" Height="{Binding}" VerticalAlignment="Bottom" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>

                                <UniformGrid Grid.Row="1" Margin="0,12,0,12" Columns="2">
                                    <Border Margin="0,0,8,0" Padding="12" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Foreground="#00ECFF" FontFamily="Consolas" FontSize="10" Text="THERMAL EFFICIENCY" />
                                            <TextBlock Margin="0,10,0,0" Foreground="#E2F2F6" FontFamily="Consolas" FontSize="12" Text="CORE TEMP VARIANCE" />
                                            <TextBlock Margin="0,4,0,0" Foreground="#00ECFF" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="22" Text="{Binding HeatIndex, StringFormat={}{0}%}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="12" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Foreground="#00ECFF" FontFamily="Consolas" FontSize="10" Text="VOLTAGE STABILITY" />
                                            <TextBlock Margin="0,10,0,0" Foreground="#E2F2F6" FontFamily="Consolas" FontSize="12" Text="PACK VOLTAGE" />
                                            <TextBlock Margin="0,4,0,0" Foreground="#E2F2F6" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="22" Text="{Binding VoltageText}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Grid.Row="2" Padding="12" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Foreground="#00ECFF" FontFamily="Consolas" FontSize="10" Text="AI ANOMALY FREQUENCY" />
                                            <Button DockPanel.Dock="Right" Width="110" Style="{StaticResource HudActionButtonStyle}" Content="EXPORT CHARTS" />
                                        </DockPanel>
                                        <TextBlock Margin="0,10,0,0" Foreground="#A2C0C8" FontFamily="Consolas" FontSize="11" Text="{Binding AnalyticsSummary}" TextWrapping="Wrap" />
                                        <Rectangle Margin="0,16,0,0" Width="26" Height="80" Fill="#9BFF4F5F" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Logic placeholder for other sections -->
                        <Border Grid.Row="0" Grid.RowSpan="3" Background="#8004080A" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                           <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAnalyticsSection}" Value="FAULT TRENDS">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedAnalyticsSection}" Value="AI ANOMALIES">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedAnalyticsSection}" Value="RELIABILITY SCORE">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#597983" FontFamily="Consolas" Text="SECTION DATA STREAM ACTIVE" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="2">
                        <Border Padding="12" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="10" Text="AI CONFIDENCE" />
                                    <TextBlock DockPanel.Dock="Right" Foreground="#00ECFF" FontFamily="Consolas" FontSize="10" Text="STABLE" />
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0" Foreground="#E6F6FA" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="46" Text="{Binding NeuralConfidence, StringFormat={}{0:F1}%}" />
                                <TextBlock Foreground="#3ABFD0" FontFamily="Consolas" FontSize="11" Text="NEURAL NET V4" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0" Padding="12" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="10" Text="ANOMALY METRICS" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="CRITICAL" Foreground="#FF5F6F" FontSize="9" FontFamily="Consolas" />
                                        <TextBlock Text="{Binding CriticalAlerts}" Foreground="#FF5F6F" FontSize="20" FontWeight="Bold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="WARNING" Foreground="#FFA040" FontSize="9" FontFamily="Consolas" />
                                        <TextBlock Text="{Binding WarningAlerts}" Foreground="#FFA040" FontSize="20" FontWeight="Bold" />
                                    </StackPanel>
                                </Grid>
                                
                                <TextBlock Margin="0,15,0,0" Foreground="#6A909A" FontFamily="Consolas" FontSize="10" Text="SYSTEM RELIABILITY" />
                                <TextBlock Margin="0,4,0,0" Foreground="#DDF1F6" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="26" Text="{Binding ReliabilityScoreText}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

