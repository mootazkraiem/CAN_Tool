<UserControl
    x:Class="CANvision.Native.UI.SectionConsoleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:CANvision.Native.UI">
    <Grid Margin="34,138,34,54">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="404" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Width="382" VerticalAlignment="Center" HorizontalAlignment="Left">
            <Grid x:Name="BriefingCardHost" Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform Y="24" />
                </Grid.RenderTransform>

                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="BriefingCardHost"
                                    Storyboard.TargetProperty="Opacity"
                                    From="0"
                                    To="1"
                                    Duration="0:0:0.38" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BriefingCardHost"
                                    Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                    From="24"
                                    To="0"
                                    Duration="0:0:0.42">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation
                                    Storyboard.TargetName="CardScanLineTransform"
                                    Storyboard.TargetProperty="X"
                                    From="-260"
                                    To="520"
                                    Duration="0:0:4.8"
                                    RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>

                <Border Style="{StaticResource HudCommandCardStyle}">
                    <Grid ClipToBounds="True">
                        <Border
                            Margin="1"
                            CornerRadius="27"
                            Background="#09263140"
                            BorderBrush="#11FFFFFF"
                            BorderThickness="1" />

                        <Rectangle Height="1" VerticalAlignment="Top" Fill="#6AEFFF" />

                        <Rectangle
                            x:Name="CardScanLine"
                            Width="120"
                            HorizontalAlignment="Left"
                            Opacity="0.15">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#00CFF8FF" Offset="0" />
                                    <GradientStop Color="#70E8FDFF" Offset="0.5" />
                                    <GradientStop Color="#00CFF8FF" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                            <Rectangle.RenderTransform>
                                <TranslateTransform x:Name="CardScanLineTransform" X="-260" />
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Rectangle Width="42" Height="1.4" Margin="18,18,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#A0F6FF" />
                        <Rectangle Width="1.4" Height="18" Margin="18,18,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#A0F6FF" />
                        <Rectangle Width="42" Height="1.4" Margin="0,18,18,0" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="#58D9F3" />
                        <Rectangle Width="1.4" Height="18" Margin="0,18,18,0" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="#58D9F3" />
                        <Rectangle Width="42" Height="1.4" Margin="18,0,0,18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Fill="#58D9F3" />
                        <Rectangle Width="1.4" Height="18" Margin="18,0,0,18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Fill="#58D9F3" />
                        <Rectangle Width="42" Height="1.4" Margin="0,0,18,18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#A0F6FF" />
                        <Rectangle Width="1.4" Height="18" Margin="0,0,18,18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#A0F6FF" />

                        <Grid Margin="30,28,30,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding SectionEyebrow}" Style="{StaticResource HudEyebrowTextStyle}" />

                            <TextBlock
                                Grid.Row="1"
                                Margin="0,14,0,0"
                                Text="{Binding SectionTitle}"
                                Style="{StaticResource HudTitleTextStyle}" />

                            <ui:TypewriterTextBlock
                                Grid.Row="2"
                                Margin="0,18,0,0"
                                Text="{Binding SectionDescription}"
                                CharacterInterval="20" />

                            <Border
                                Grid.Row="3"
                                Margin="0,24,0,0"
                                Padding="12,6"
                                HorizontalAlignment="Left"
                                CornerRadius="999"
                                Background="#1300E9FF"
                                BorderBrush="#2A8DE7FF"
                                BorderThickness="1">
                                <TextBlock Text="{Binding SectionSignalLine}" Style="{StaticResource HudMutedTextStyle}" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Button
                x:Name="PrimaryActionButton"
                Margin="0,18,0,0"
                Opacity="0"
                Style="{StaticResource HudHeroCapsuleButtonStyle}"
                Command="{Binding DataContext.NavigationService.NavigateToSectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding PrimaryActionTargetKey}">
                <Button.RenderTransform>
                    <TranslateTransform Y="16" />
                </Button.RenderTransform>

                <Button.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="PrimaryActionButton"
                                    Storyboard.TargetProperty="Opacity"
                                    From="0"
                                    To="1"
                                    BeginTime="0:0:0.12"
                                    Duration="0:0:0.42" />
                                <DoubleAnimation
                                    Storyboard.TargetName="PrimaryActionButton"
                                    Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                    From="16"
                                    To="0"
                                    BeginTime="0:0:0.12"
                                    Duration="0:0:0.42">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>

                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="{Binding PrimaryActionLabel}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        FontFamily="Consolas"
                        FontSize="17"
                        Text=">" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
