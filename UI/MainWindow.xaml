<Window
    x:Class="CANvision.Native.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:scene="clr-namespace:CANvision.Native.Scene"
    xmlns:ui="clr-namespace:CANvision.Native.UI"
    Title="CANvision Native Garage"
    Width="1600"
    Height="940"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    Background="#04070B">
    <Grid ClipToBounds="False">
        <Grid
            x:Name="LandingLayer"
            Visibility="{Binding IsLandingScreenVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Image
                x:Name="BackgroundImageLayer"
                Panel.ZIndex="0"
                Source="{Binding BackgroundImage}"
                Stretch="UniformToFill"
                SnapsToDevicePixels="True"
                Opacity="0"
                IsHitTestVisible="False"
                RenderOptions.BitmapScalingMode="HighQuality" />

            <Rectangle Panel.ZIndex="1" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#62030B12" Offset="0" />
                        <GradientStop Color="#22050C13" Offset="0.34" />
                        <GradientStop Color="#78040A12" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Panel.ZIndex="2" IsHitTestVisible="False" Opacity="0.42">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.58,0.44" GradientOrigin="0.58,0.44" RadiusX="0.85" RadiusY="0.78">
                        <GradientStop Color="#00000000" Offset="0.0" />
                        <GradientStop Color="#1400D7F8" Offset="0.56" />
                        <GradientStop Color="#48010712" Offset="1.0" />
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Canvas Panel.ZIndex="3" IsHitTestVisible="False">
                <Ellipse Width="7" Height="7" Canvas.Left="168" Canvas.Top="214" Fill="#33EAFDFF" Opacity="0.1">
                    <Ellipse.Effect>
                        <BlurEffect Radius="8" />
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <TranslateTransform />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.05" To="0.18" Duration="0:0:3.8" />
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)" From="0" To="-28" Duration="0:0:8.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <Ellipse Width="9" Height="9" Canvas.Left="1324" Canvas.Top="198" Fill="#28D8F6FF" Opacity="0.08">
                    <Ellipse.Effect>
                        <BlurEffect Radius="10" />
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <TranslateTransform />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.04" To="0.16" Duration="0:0:4.4" />
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)" From="0" To="-34" Duration="0:0:9.6" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <Ellipse Width="6" Height="6" Canvas.Left="1186" Canvas.Top="612" Fill="#2CECFDFF" Opacity="0.08">
                    <Ellipse.Effect>
                        <BlurEffect Radius="7" />
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <TranslateTransform />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.04" To="0.14" Duration="0:0:3.4" />
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)" From="0" To="-22" Duration="0:0:7.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <Ellipse Width="5" Height="5" Canvas.Left="356" Canvas.Top="664" Fill="#22F7FFFF" Opacity="0.07">
                    <Ellipse.Effect>
                        <BlurEffect Radius="6" />
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <TranslateTransform />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.03" To="0.12" Duration="0:0:4.1" />
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)" From="0" To="-18" Duration="0:0:6.8" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </Canvas>

            <ContentControl
                x:Name="GarageSceneHost"
                Panel.ZIndex="4"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />

            <ContentControl
                Panel.ZIndex="5"
                Content="{Binding HomeSection}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />
        </Grid>

        <Grid
            x:Name="HubLayer"
            Panel.ZIndex="8"
            Visibility="{Binding IsHubVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <ContentControl
                Content="{Binding HubSection}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />
        </Grid>

        <Grid
            x:Name="InterfaceLayer"
            Panel.ZIndex="10"
            Background="#0B0F0F"
            Visibility="{Binding IsSectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"
            Opacity="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.Resources>
                <Style TargetType="Thumb">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="#4D00FFFF" CornerRadius="3" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="RepeatButton">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="RepeatButton">
                                <Rectangle Fill="Transparent" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="ScrollBar">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Width" Value="6" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Height" Value="0" />
                            <Setter Property="Opacity" Value="0" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Grid.Resources>
            <Grid
                x:Name="SectionContentHost"
                Grid.Row="1"
                Margin="16,12,16,16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="SectionContentTranslate" />
                </Grid.RenderTransform>

                <ContentControl Content="{Binding CurrentSection}" />
            </Grid>

            <Button
                Grid.Row="0"
                Panel.ZIndex="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="16,16,0,0"
                Style="{StaticResource HudActionButtonStyle}"
                Command="{Binding NavigationService.BackToHubCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontFamily="Consolas"
                        FontSize="16"
                        Text="&lt;" />
                    <TextBlock VerticalAlignment="Center" Text="Back To Cards" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
