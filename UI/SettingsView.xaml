<UserControl
    x:Class="CANvision.Native.UI.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:CANvision.Native.ViewModels">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://siteoforigin:,,,/assets/6k+-D+copy+-+High+Contrast.webp" Stretch="UniformToFill" Opacity="0.23" />
        </Grid.Background>
        <Rectangle Fill="#E0080C0F" />

        <Grid Margin="24,20,24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Grid.RowSpan="2" Padding="12" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="10" Text="SYSTEM NODES" />
                    <ItemsControl Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding SettingsCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,8" Padding="10,6" HorizontalContentAlignment="Left" Command="{Binding DataContext.SelectSettingsCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource HudActionButtonStyle}">
                                            <Setter Property="Background" Value="#7F0A0E10" />
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="10" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="2" Padding="8" Background="#780A0E10" BorderBrush="#1E2F363C" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="9" Text="LINK STATUS" />
                            <TextBlock Margin="0,3,0,0" Foreground="#DDF1F6" FontFamily="Consolas" FontSize="10" Text="{Binding RuntimeMode}" />
                            <TextBlock Margin="0,3,0,0" Foreground="#7B9CA6" FontFamily="Consolas" FontSize="9" Text="LATENCY: {Binding LatencyText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Grid.Row="0" Margin="16,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="14" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Foreground="#11EDFF" FontFamily="Consolas" FontSize="24" FontWeight="Bold" Text="HARDWARE INTERFACE" />
                            <TextBlock Margin="0,2,0,12" Foreground="#6A909A" FontFamily="Consolas" FontSize="10" Text="PROTOCOL AND COM CONFIGURATION" />
                            <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="9" Text="OBD2 ADAPTER SELECTOR" />
                            <TextBox Margin="0,4,0,10" Style="{StaticResource HudLineTextBoxStyle}" Text="{Binding AdapterName}" />
                            <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="9" Text="BAUD RATE" />
                            <TextBox Margin="0,4,0,0" Style="{StaticResource HudLineTextBoxStyle}" Text="{Binding BaudRateText}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="9" Text="COM PORT" />
                            <TextBox Margin="0,4,0,10" Style="{StaticResource HudLineTextBoxStyle}" Text="{Binding PortName}" />
                            <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="9" Text="CAN CHANNEL" />
                            <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                <Button Width="110" Margin="0,0,8,0" Style="{StaticResource HudActionButtonStyle}" Content="CHANNEL A" />
                                <Button Width="110" Style="{StaticResource HudActionButtonStyle}" Content="CHANNEL B" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="0,12,0,12" Padding="14" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="#11EDFF" FontFamily="Consolas" FontSize="24" FontWeight="Bold" Text="NEURAL CORE CONFIG" />
                            <TextBlock Margin="0,2,0,12" Foreground="#6A909A" FontFamily="Consolas" FontSize="10" Text="AUTONOMOUS ANOMALY DETECTION" />
                            <TextBlock Foreground="#DFF2F6" FontFamily="Consolas" FontSize="11" Text="ENABLE ANOMALY DETECTION" />
                            <TextBlock Margin="0,4,0,12" Foreground="#6A909A" FontFamily="Consolas" FontSize="9" Text="Real-time telemetry pattern matching and fault prediction" />
                            <Border Padding="10" Background="#780A0E10" BorderBrush="#1E2F363C" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="9" Text="DETECTION MODEL" />
                                    <TextBlock Margin="0,6,0,0" Foreground="#11EDFF" FontFamily="Consolas" FontSize="11" Text="{Binding DetectionModelText}" />
                                    <TextBlock Margin="0,4,0,0" Foreground="#7D9EA8" FontFamily="Consolas" FontSize="9" Text="Training: {Binding TrainingDateText} | Accuracy: {Binding AccuracyText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                            <Border Padding="8" Background="#2300F6FF" BorderBrush="#2A8CE4F8" BorderThickness="1">
                                <TextBlock Foreground="#11EDFF" FontFamily="Consolas" FontSize="10" HorizontalAlignment="Center" Text="CORE ACTIVE" />
                            </Border>
                            <CheckBox Margin="0,22,0,0" Style="{StaticResource HudCheckBoxStyle}" IsChecked="True" Content="Anomaly Detection Enabled" />
                            <TextBlock Margin="0,16,0,0" Foreground="#6A909A" FontFamily="Consolas" FontSize="9" Text="DETECTION SENSITIVITY" />
                            <Slider Margin="0,8,0,0" Minimum="0" Maximum="100" Value="85" />
                            <Button Margin="0,16,0,0" Style="{StaticResource HudActionButtonStyle}" Content="RETRAIN LOCAL WEIGHTS" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Padding="12" Background="#AA0A0F11" BorderBrush="#253A41" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="10" Text="VEHICLE PROFILES" />
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ProfileCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ProfileItem}">
                                    <Border Margin="0,0,0,8" Padding="10" Background="#760A0E10" BorderBrush="#1E2F363C" BorderThickness="1">
                                        <DockPanel>
                                            <StackPanel>
                                                <TextBlock Foreground="#DFF2F6" FontFamily="Consolas" FontSize="11" Text="{Binding Name}" />
                                                <TextBlock Margin="0,3,0,0" Foreground="#7D9EA8" FontFamily="Consolas" FontSize="9" Text="{Binding Description}" />
                                            </StackPanel>
                                            <TextBlock DockPanel.Dock="Right" Foreground="#11EDFF" FontFamily="Consolas" FontSize="10" Text="{Binding State}" VerticalAlignment="Center" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="140" Margin="0,0,10,0" Style="{StaticResource HudActionButtonStyle}" Content="RESTORE DEFAULTS" />
                <Button Width="110" Margin="0,0,10,0" Style="{StaticResource HudActionButtonStyle}" Content="CANCEL" />
                <Button Width="130" Style="{StaticResource HudActionButtonStyle}" Content="SAVE SETTINGS" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
