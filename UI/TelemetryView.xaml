<UserControl
    x:Class="CANvision.Native.UI.TelemetryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:CANvision.Native.ViewModels">
    <Grid>
        <Grid.Background>
            <ImageBrush
                ImageSource="pack://siteoforigin:,,,/assets/6k+-D+copy+-+High+Contrast.webp"
                Stretch="UniformToFill"
                Opacity="0.45" />
        </Grid.Background>

        <Rectangle Fill="#D90B0F0F" />
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.52,0.45" GradientOrigin="0.52,0.45" RadiusX="0.65" RadiusY="0.52">
                    <GradientStop Color="#1400F6FF" Offset="0" />
                    <GradientStop Color="#900B0F0F" Offset="0.62" />
                    <GradientStop Color="#ED0B0F0F" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            CanContentScroll="True">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="0,0,0,16" Style="{StaticResource HudCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HudEyebrowTextStyle}" Text="UNIT" />
                            <TextBlock
                                Margin="0,10,0,0"
                                Foreground="{StaticResource AccentCyanBrush}"
                                FontFamily="{StaticResource HeadlineFontFamily}"
                                FontSize="18"
                                FontWeight="Bold"
                                Text="CAN_01" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource HudCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HudEyebrowTextStyle}" Text="FILTER" />
                            <TextBox Margin="0,14,0,0" Style="{StaticResource HudLineTextBoxStyle}" Text="FILTER SIGNALS..." />
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Margin="0,0,6,0" Style="{StaticResource HudComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem>ALL SEVERITY</ComboBoxItem>
                                    <ComboBoxItem>LIVE</ComboBoxItem>
                                    <ComboBoxItem>ALERT</ComboBoxItem>
                                </ComboBox>
                                <ComboBox Grid.Column="1" Margin="6,0,0,0" Style="{StaticResource HudComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem>DIAGNOSTICS</ComboBoxItem>
                                    <ComboBoxItem>POWERTRAIN</ComboBoxItem>
                                    <ComboBoxItem>THERMAL</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Margin="0,16,0,0" Style="{StaticResource HudCardStyle}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Style="{StaticResource HudEyebrowTextStyle}" Text="SIGNAL REGISTRY" />
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource HudMutedTextStyle}" Text="L_128_MS" />
                            </DockPanel>

                            <Grid Margin="0,16,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="84" />
                                    <ColumnDefinition Width="44" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource HudMutedTextStyle}" Text="ID" />
                                <TextBlock Grid.Column="1" Style="{StaticResource HudMutedTextStyle}" Text="NAME" />
                                <TextBlock Grid.Column="2" Style="{StaticResource HudMutedTextStyle}" Text="VALUE" />
                                <TextBlock Grid.Column="3" Style="{StaticResource HudMutedTextStyle}" Text="SEV" />
                            </Grid>

                            <ScrollViewer
                                Height="520"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding SignalRows}" AlternationCount="2">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:SignalItem}">
                                            <Border Margin="0,0,0,6" Padding="8,6" Background="#14000000" BorderBrush="#11343A" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="60" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="44" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource HudMutedTextStyle}" Text="{Binding CanId}" />
                                                    <TextBlock Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}" Style="{StaticResource HudBodyTextStyle}" Text="{Binding Name}" />
                                                    <TextBlock Grid.Column="2" Foreground="{StaticResource AccentCyanBrush}" Style="{StaticResource HudBodyTextStyle}" Text="{Binding Value}" />
                                                    <Border Grid.Column="3" Width="20" Height="20" HorizontalAlignment="Center" BorderBrush="#304046" BorderThickness="1">
                                                        <Rectangle Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Rectangle.Style>
                                                                <Style TargetType="Rectangle">
                                                                    <Setter Property="Fill" Value="#3B6B76" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding State}" Value="ALERT">
                                                                            <Setter Property="Fill" Value="#FF716C" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding State}" Value="LIVE">
                                                                            <Setter Property="Fill" Value="#00FFFF" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Rectangle.Style>
                                                        </Rectangle>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="1" Margin="0,0,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,12">
                        <Button Margin="0,0,8,0" Style="{StaticResource HudNavButtonStyle}" Tag="True" Content="BATTERY" />
                        <Button Margin="0,0,8,0" Style="{StaticResource HudNavButtonStyle}" Content="MOTOR" />
                        <Button Margin="0,0,8,0" Style="{StaticResource HudNavButtonStyle}" Content="THERMAL" />
                        <Button Style="{StaticResource HudNavButtonStyle}" Content="ELECTRICAL" />
                    </UniformGrid>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{StaticResource AccentCyanBrush}" FontFamily="Consolas" FontSize="11" Text="TRACE 01: SOC_CELL_AVG [84.2%]" />
                        <TextBlock Grid.Column="1" Foreground="#84C7FF" FontFamily="Consolas" FontSize="11" Text="TRACE 02: CELL_MAX_V [3.94V]" />
                    </Grid>

                    <Border Grid.Row="2" Style="{StaticResource HudHeroCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,16">
                                <Rectangle Fill="#0F0F0F" Stroke="#25383E" StrokeThickness="1" />
                                <Grid Margin="18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Rectangle Grid.Row="0" Grid.ColumnSpan="6" Height="1" VerticalAlignment="Bottom" Fill="#112A2F" />
                                    <Rectangle Grid.Row="1" Grid.ColumnSpan="6" Height="1" VerticalAlignment="Bottom" Fill="#112A2F" />
                                    <Rectangle Grid.Row="2" Grid.ColumnSpan="6" Height="1" VerticalAlignment="Bottom" Fill="#112A2F" />
                                    <Rectangle Grid.Row="3" Grid.ColumnSpan="6" Height="1" VerticalAlignment="Bottom" Fill="#112A2F" />
                                    <Rectangle Grid.Column="0" Grid.RowSpan="4" Width="1" HorizontalAlignment="Right" Fill="#112A2F" />
                                    <Rectangle Grid.Column="1" Grid.RowSpan="4" Width="1" HorizontalAlignment="Right" Fill="#112A2F" />
                                    <Rectangle Grid.Column="2" Grid.RowSpan="4" Width="1" HorizontalAlignment="Right" Fill="#112A2F" />
                                    <Rectangle Grid.Column="3" Grid.RowSpan="4" Width="1" HorizontalAlignment="Right" Fill="#112A2F" />
                                    <Rectangle Grid.Column="4" Grid.RowSpan="4" Width="1" HorizontalAlignment="Right" Fill="#112A2F" />
                                    <Rectangle Grid.Column="5" Grid.RowSpan="4" Width="1" HorizontalAlignment="Right" Fill="#112A2F" />

                                    <Polyline Grid.RowSpan="4" Grid.ColumnSpan="6" Stroke="{StaticResource AccentCyanBrush}" StrokeThickness="2.4" Points="0,180 80,168 160,196 240,110 320,76 400,104 480,142 560,172" />
                                    <Polyline Grid.RowSpan="4" Grid.ColumnSpan="6" Stroke="#4C84C7FF" StrokeThickness="1.8" Points="0,228 80,220 160,238 240,218 320,176 400,244 480,286 560,228" />
                                </Grid>

                                <TextBlock Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#516A71" FontFamily="Consolas" FontSize="9" Text="100" />
                                <TextBlock Margin="10,0,0,10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Foreground="#516A71" FontFamily="Consolas" FontSize="9" Text="0" />
                                <TextBlock Margin="0,0,10,10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="#516A71" FontFamily="Consolas" FontSize="9" Text="60s" />
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource HudActionButtonStyle}" MinWidth="120" Content="+ ADD SIGNAL" />
                                <Button Grid.Column="1" Margin="0,0,10,0" Style="{StaticResource HudActionButtonStyle}" MinWidth="120" Content="- REMOVE" />

                                <Button Grid.Column="3" Margin="0,0,8,0" Style="{StaticResource HudNavButtonStyle}" MinWidth="44" Content="+" />
                                <Button Grid.Column="4" Margin="0,0,8,0" Style="{StaticResource HudNavButtonStyle}" MinWidth="44" Content="-" />
                                <Button Grid.Column="5" Margin="0,0,8,0" Style="{StaticResource HudNavButtonStyle}" MinWidth="60" Content="PAUSE" />
                                <Button Grid.Column="6" Style="{StaticResource HudNavButtonStyle}" MinWidth="60" Content="RESET" />
                            </Grid>
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="3" Columns="4" Margin="0,14,0,0">
                        <Button Margin="0,0,10,0" Style="{StaticResource HudActionButtonStyle}" MinWidth="0" Content="IMPORT LOG" />
                        <Button Margin="0,0,10,0" Style="{StaticResource HudActionButtonStyle}" MinWidth="0" Content="EXPORT SIGNALS" />
                        <Button Margin="0,0,10,0" Style="{StaticResource HudActionButtonStyle}" MinWidth="0" Background="#55151414" BorderBrush="#88FF716C" Content="FREEZE STREAM" />
                        <Button Style="{StaticResource HudActionButtonStyle}" MinWidth="0" Background="#3300FFFF" BorderBrush="#CC00FFFF" Content="RESUME STREAM" />
                    </UniformGrid>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource HudCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HudEyebrowTextStyle}" Text="STREAM STATUS" />
                            <UniformGrid Margin="0,18,0,0" Columns="2">
                                <StackPanel Margin="0,0,12,12">
                                    <TextBlock Style="{StaticResource HudMutedTextStyle}" Text="PACKET RATE" />
                                    <TextBlock Foreground="{StaticResource AccentCyanBrush}" Style="{StaticResource HudMetricValueTextStyle}" FontSize="26" Text="{Binding PacketRateText}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Style="{StaticResource HudMutedTextStyle}" Text="PACKET LOSS" />
                                    <TextBlock Foreground="#FF716C" Style="{StaticResource HudMetricValueTextStyle}" FontSize="26" Text="{Binding PacketLossText}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource HudMutedTextStyle}" Text="SAMPLE RATE" />
                                    <TextBlock Style="{StaticResource HudMetricValueTextStyle}" FontSize="26" Text="{Binding SampleRateText}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource HudMutedTextStyle}" Text="LATENCY" />
                                    <TextBlock Style="{StaticResource HudMetricValueTextStyle}" FontSize="26" Text="{Binding LatencyText}" />
                                </StackPanel>
                            </UniformGrid>

                            <Border Margin="0,16,0,0" Padding="10,8" Background="#1A2023" BorderBrush="#304046" BorderThickness="1">
                                <TextBlock Foreground="{StaticResource AccentCyanBrush}" Style="{StaticResource HudBodyTextStyle}" Text="{Binding AdapterName}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Margin="0,16,0,0" Style="{StaticResource HudCardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource HudEyebrowTextStyle}" Text="SYSTEM ALERTS" />
                                <Border DockPanel.Dock="Right" Padding="6,2" Background="#3A1514" BorderBrush="#88FF716C" BorderThickness="1">
                                    <TextBlock Foreground="#FF716C" FontFamily="Consolas" FontSize="9" Text="ACTIVE" />
                                </Border>
                            </DockPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Height="560">
                                <StackPanel>
                                    <Border Margin="0,0,0,10" Padding="14" Style="{StaticResource HudStatusCardStyle}" Tag="CRITICAL">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Foreground="#FF716C" Style="{StaticResource HudEyebrowTextStyle}" Text="CRITICAL OVERHEAT" />
                                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource HudMutedTextStyle}" Text="{Binding UpdatedText}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,10,0,0" Style="{StaticResource HudBodyTextStyle}" Text="{Binding CoolingHeadroomText}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,0,0,10" Padding="14" Style="{StaticResource HudStatusCardStyle}" Tag="WATCH">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Foreground="#F3D15A" Style="{StaticResource HudEyebrowTextStyle}" Text="SIGNAL LAG" />
                                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource HudMutedTextStyle}" Text="{Binding CaptureCadenceText}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,10,0,0" Style="{StaticResource HudBodyTextStyle}" Text="{Binding EnergyNarrative}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="14" Style="{StaticResource HudStatusCardStyle}" Tag="GOOD">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Foreground="{StaticResource AccentCyanBrush}" Style="{StaticResource HudEyebrowTextStyle}" Text="BUS LOAD" />
                                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource HudMutedTextStyle}" Text="{Binding SourceText}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,10,0,0" Style="{StaticResource HudBodyTextStyle}" Text="{Binding BusLoadText}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
