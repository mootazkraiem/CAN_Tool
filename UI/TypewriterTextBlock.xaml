<UserControl
    x:Class="CANvision.Native.UI.TypewriterTextBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TextBlock
        x:Name="TextHost"
        Foreground="{StaticResource SecondaryTextBrush}"
        FontSize="15"
        FontFamily="{StaticResource BodyFontFamily}"
        TextWrapping="Wrap">
        <Run x:Name="DisplayRun" />
        <Run x:Name="CursorRun" Text="|">
            <Run.Foreground>
                <SolidColorBrush x:Name="CursorBrush" Color="{StaticResource AccentCyanColor}" Opacity="1" />
            </Run.Foreground>
        </Run>
    </TextBlock>
</UserControl>
