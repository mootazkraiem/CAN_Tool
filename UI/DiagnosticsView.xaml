<UserControl
    x:Class="CANvision.Native.UI.DiagnosticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:CANvision.Native.ViewModels"
    xmlns:converters="clr-namespace:CANvision.Native.Converters">
    <Grid>
        <Grid.Background>
            <ImageBrush
                ImageSource="pack://siteoforigin:,,,/assets/6k+-D+copy+-+High+Contrast.webp"
                Stretch="UniformToFill"
                Opacity="0.3" />
        </Grid.Background>

        <Rectangle Fill="#D9090D10" />
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.45" GradientOrigin="0.5,0.45" RadiusX="0.65" RadiusY="0.55">
                    <GradientStop Color="#1C00F3FF" Offset="0" />
                    <GradientStop Color="#B20A0F12" Offset="0.66" />
                    <GradientStop Color="#F4090D10" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid>
            <!-- Calibration Overlay -->
            <Border Background="#F0080C0F" Visibility="{Binding IsCalibrating, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Visible}" Panel.ZIndex="1000">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="SYSTEM STABILIZATION IN PROGRESS..." 
                               Foreground="#00ECFF" 
                               FontFamily="{StaticResource HeadlineFontFamily}" 
                               FontSize="24" 
                               TextAlignment="Center" />
                    <TextBlock Text="{Binding CalibrationText}" Margin="0,10,0,0" Foreground="#597983" FontFamily="Consolas" FontSize="14" TextAlignment="Center" />
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True">
                <Grid Margin="24,24,24,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Column="0" Grid.RowSpan="3" Padding="12" Background="#A5090D10" BorderBrush="#2D2F3D43" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Foreground="#5D7F89" FontFamily="Consolas" FontSize="10" Text="SUBSYSTEM TOPOLOGY" />

                            <ItemsControl Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding Subsystems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Padding="8,6" Background="#8A0A0E11" BorderBrush="#1F334047" BorderThickness="1">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectSubsystemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Name}" />
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#D1EAF0" FontFamily="Consolas" FontSize="10" Text="{Binding Name}" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Foreground="#57B6C7" FontFamily="Consolas" FontSize="9" Text="{Binding State}" />
                                                    <TextBlock Margin="6,0,0,0" Foreground="#00F0FF" FontSize="12" Text="|" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <TextBlock Foreground="#4D6E77" FontFamily="Consolas" FontSize="9" Text="VOLTAGE_PACK" />
                                <TextBlock Margin="0,4,0,0" Foreground="#1DEFFF" FontFamily="Consolas" FontSize="20" Text="{Binding BatteryVoltageText}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="0" Margin="16,0,16,12" Padding="16" Background="#B3090E11" BorderBrush="#243941" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Width="92" Height="92" VerticalAlignment="Center">
                                <Ellipse Stroke="#2C5460" StrokeThickness="8" />
                                <Ellipse Stroke="#11EFFF" StrokeThickness="8" StrokeDashCap="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Ellipse.StrokeDashArray>0.84 0.16</Ellipse.StrokeDashArray>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" Foreground="#00F3FF" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Text="{Binding ConfidenceScore, StringFormat={}{0:F0}%}" />
                                    <TextBlock HorizontalAlignment="Center" Foreground="#5A8793" FontFamily="Consolas" FontSize="9" Text="RELIABILITY" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <TextBlock Foreground="#E5F7FA" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="30" FontWeight="Bold" Text="{Binding DiagnosticsStatus}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0" Foreground="#3BD8E9" FontFamily="Consolas" FontSize="10" Text="POLLING SUB-NEURAL CONTROLLER CLUSTERS..." />
                                <DockPanel Margin="0,10,0,0">
                                    <TextBlock Foreground="#678B95" FontFamily="Consolas" FontSize="9" Text="{Binding UpdatedText, StringFormat=TIMESTAMP: {0}}" />
                                    <TextBlock DockPanel.Dock="Right" Foreground="#678B95" FontFamily="Consolas" FontSize="9" Text="NODE: NEURAL_X04" />
                                </DockPanel>
                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                    <Button Width="116" Margin="0,0,10,0" Style="{StaticResource HudActionButtonStyle}" Command="{Binding RunFullScanCommand}" Content="RUN FULL SCAN" />
                                    <Button Width="94" Margin="0,0,10,0" Style="{StaticResource HudActionButtonStyle}" Command="{Binding ClearAlertsCommand}" Content="CLEAR" />
                                    <Button Width="96" Style="{StaticResource HudActionButtonStyle}" Command="{Binding StopScanCommand}" Content="STOP SCAN" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="1" Margin="16,0,16,12" Padding="0" Background="#B0090E11" BorderBrush="#223741" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="14,10,14,8">
                                <TextBlock Foreground="#9ABBC3" FontFamily="Consolas" FontSize="10" Text="DIAGNOSTIC TROUBLE CODES (DTC)" />
                                <TextBlock DockPanel.Dock="Right" Foreground="#0DF1FF" FontFamily="Consolas" FontSize="9" Text="{Binding FilteredDtcRows.Count, StringFormat='Filtered Faults: {0}'}" />
                            </DockPanel>

                            <!-- Filter Bar -->
                            <StackPanel Grid.Row="1" Margin="14,0,14,8" Orientation="Horizontal">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Foreground="#4E7078" FontFamily="Consolas" FontSize="8" Text="FILTER CODE/DESC" />
                                    <TextBox Width="120" Background="#20000000" Foreground="#D1EAF0" BorderBrush="#3000F6FF" Text="{Binding FilterCode, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Foreground="#4E7078" FontFamily="Consolas" FontSize="8" Text="SEVERITY" />
                                    <ComboBox Width="90" Background="#20000000" Foreground="#D1EAF0" BorderBrush="#3000F6FF" ItemsSource="{Binding SeverityFilterOptions}" SelectedItem="{Binding FilterSeverity}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Foreground="#4E7078" FontFamily="Consolas" FontSize="8" Text="SUBSYSTEM" />
                                    <ComboBox Width="100" Background="#20000000" Foreground="#D1EAF0" BorderBrush="#3000F6FF" ItemsSource="{Binding SourceFilterOptions}" SelectedItem="{Binding FilterSource}" />
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="2" Margin="14,0,14,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="#587983" FontFamily="Consolas" FontSize="9" Text="CODE" />
                                    <TextBlock Grid.Column="1" Foreground="#587983" FontFamily="Consolas" FontSize="9" Text="DESCRIPTION" />
                                    <TextBlock Grid.Column="2" Foreground="#587983" FontFamily="Consolas" FontSize="9" Text="SEVERITY" />
                                    <TextBlock Grid.Column="3" Foreground="#587983" FontFamily="Consolas" FontSize="9" Text="SOURCE" />
                                    <TextBlock Grid.Column="4" Foreground="#587983" FontFamily="Consolas" FontSize="9" Text="TIMESTAMP" />
                                </Grid>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredDtcRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,6" Padding="8,6" Background="#8A0A0F12" BorderBrush="#1A2F3940" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="112" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="112" />
                                                            <ColumnDefinition Width="92" />
                                                            <ColumnDefinition Width="82" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Foreground="#00EBFF" FontFamily="Consolas" FontSize="10" Text="{Binding Code}" />
                                                        <TextBlock Grid.Column="1" Foreground="#DCEEF2" FontFamily="Consolas" FontSize="10" Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                                        <Border Grid.Column="2" Width="84" Padding="5,2" Background="#31131518" BorderBrush="#503D464C" BorderThickness="1" HorizontalAlignment="Left">
                                                            <TextBlock Foreground="#E9AAB0" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center" Text="{Binding Severity}" />
                                                        </Border>
                                                        <TextBlock Grid.Column="3" Foreground="#97B4BC" FontFamily="Consolas" FontSize="9" Text="{Binding Source}" />
                                                        <TextBlock Grid.Column="4" Foreground="#97B4BC" FontFamily="Consolas" FontSize="9" Text="{Binding TimestampText}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Grid.Row="2" Margin="16,0,16,0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Width="158" Margin="0,0,14,0" Style="{StaticResource HudActionButtonStyle}" Command="{Binding ExportReportCommand}" Content="EXPORT REPORT" />
                        <Button Width="158" Style="{StaticResource HudActionButtonStyle}" Command="{Binding SaveSnapshotCommand}" Content="SAVE SNAPSHOT" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Grid.RowSpan="3" Margin="0,0,0,0">
                        <Border Padding="12" Background="#B20A0F12" BorderBrush="#223741" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Foreground="#00F0FF" FontFamily="Consolas" FontSize="10" Text="AI ANOMALY HUB" />
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock Foreground="#59AFC0" FontFamily="Consolas" FontSize="9" Text="NEURAL CONFIDENCE" />
                                    <TextBlock DockPanel.Dock="Right" Foreground="#1DEFFF" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="26" FontWeight="Bold" Text="{Binding ConfidenceScore}" />
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0" Foreground="#B8D1D8" FontFamily="Consolas" FontSize="9" Text="Signal asymmetry detected in subsystem transition clusters. Recommend immediate actuator review." TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0" Padding="12" Background="#B20A0F12" BorderBrush="#223741" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Foreground="#6A8F98" FontFamily="Consolas" FontSize="10" Text="RECOMMENDED PROTOCOLS" />
                                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding RecommendedActions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:RecommendationItem}">
                                            <Border Margin="0,0,0,8" Padding="8" Background="#880A0E11" BorderBrush="#1E2F3940" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Foreground="#16EFFF" FontFamily="Consolas" FontSize="9" Text="{Binding Title}" />
                                                    <TextBlock Margin="0,4,0,0" Foreground="#A9C4CC" FontFamily="Consolas" FontSize="9" Text="{Binding Detail}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0" Padding="12" Background="#B20A0F12" BorderBrush="#223741" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Foreground="#6A8F98" FontFamily="Consolas" FontSize="10" Text="RAW AI ANOMALIES" />
                                <Grid Margin="0,8,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="#4E7078" FontFamily="Consolas" FontSize="8" Text="ID" />
                                    <TextBlock Grid.Column="1" Foreground="#4E7078" FontFamily="Consolas" FontSize="8" Text="SEV" />
                                    <TextBlock Grid.Column="2" Foreground="#4E7078" FontFamily="Consolas" FontSize="8" Text="SCORE" />
                                </Grid>
                                <ScrollViewer Height="180" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding RawAnomalies}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,4" Padding="6,4" Background="#880A0E11" BorderBrush="#1E2F3940" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60" />
                                                            <ColumnDefinition Width="40" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Foreground="#0DF1FF" FontFamily="Consolas" FontSize="9" Text="{Binding RelatedCanId, StringFormat='0x{}{0:X3}'}" />
                                                        <TextBlock Grid.Column="1" FontFamily="Consolas" FontSize="9" Text="{Binding SeverityScore, StringFormat='{}{0:F0}'}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#00F6FF" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding SeverityScore, Converter={StaticResource GreaterThanConverter}, ConverterParameter=80}" Value="True">
                                                                            <Setter Property="Foreground" Value="#FF4D4D" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding SeverityScore, Converter={StaticResource GreaterThanConverter}, ConverterParameter=40}" Value="True">
                                                                            <Setter Property="Foreground" Value="#FFAD33" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="2" Foreground="#8AAAB3" FontFamily="Consolas" FontSize="9" Text="{Binding AnomalyScore, StringFormat='{}{0:F4}'}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <Button Margin="0,12,0,0" Width="180" Style="{StaticResource HudActionButtonStyle}" Command="{Binding ClearAlertsCommand}" Content="CLEAR LOGS" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

