<UserControl
    x:Class="CANvision.Native.UI.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:CANvision.Native.UI">
    <Grid Margin="0">
        <Border
            x:Name="CommandCardHost"
            Margin="40"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Padding="20,16"
            Opacity="0"
            Background="#BB091012"
            BorderBrush="#4400FFFF"
            BorderThickness="1"
            CornerRadius="8">
            <Border.RenderTransform>
                <TranslateTransform Y="18" />
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="CommandCardHost"
                                Storyboard.TargetProperty="Opacity"
                                From="0"
                                To="1"
                                Duration="0:0:0.38" />
                            <DoubleAnimation
                                Storyboard.TargetName="CommandCardHost"
                                Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                From="18"
                                To="0"
                                Duration="0:0:0.42">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <StackPanel>
                <TextBlock
                    Text="GARAGE COMMAND DECK"
                    Foreground="#9CDFF0"
                    FontSize="11"
                    FontFamily="Consolas" />
                <TextBlock
                    Margin="0,8,0,0"
                    Text="READY"
                    Foreground="#FFFFFF"
                    FontSize="28"
                    FontWeight="SemiBold" />
                <TextBlock
                    Margin="0,10,0,0"
                    Text="{Binding ConnectivityText}"
                    Foreground="#A7BCC4"
                    FontSize="12" />
            </StackPanel>
        </Border>

        <Button
            x:Name="EnterSystemButton"
            Margin="0,0,0,80"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            IsEnabled="True"
            Opacity="0"
            Style="{StaticResource HudHeroCapsuleButtonStyle}"
            Command="{Binding DataContext.NavigationService.EnterSystemCommand, RelativeSource={RelativeSource AncestorType=Window}}">
            <Button.RenderTransform>
                <TranslateTransform Y="16" />
            </Button.RenderTransform>

            <Button.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="EnterSystemButton"
                                Storyboard.TargetProperty="Opacity"
                                From="0"
                                To="1"
                                BeginTime="0:0:0.12"
                                Duration="0:0:0.42" />
                            <DoubleAnimation
                                Storyboard.TargetName="EnterSystemButton"
                                Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                From="16"
                                To="0"
                                BeginTime="0:0:0.12"
                                Duration="0:0:0.42">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>

            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="Dive In" />
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Consolas"
                    FontSize="17"
                    Text=">" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
