<UserControl
    x:Class="CANvision.Native.UI.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:CANvision.Native.UI">
    <Grid Margin="0">
        <Grid
            x:Name="CommandCardHost"
            Margin="24,24,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Opacity="0">
            <Grid>
                <Grid.RenderTransform>
                    <TranslateTransform Y="24" />
                </Grid.RenderTransform>

                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="CommandCardHost"
                                    Storyboard.TargetProperty="Opacity"
                                    From="0"
                                    To="1"
                                    Duration="0:0:0.38" />
                                <DoubleAnimation
                                    Storyboard.TargetName="CommandCardHost"
                                    Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                    From="24"
                                    To="0"
                                    Duration="0:0:0.42">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>

                <Border Style="{StaticResource HudCommandCardStyle}">
                    <Grid ClipToBounds="True">
                        <Border
                            Margin="1"
                            CornerRadius="27"
                            Background="#09263140"
                            BorderBrush="#11FFFFFF"
                            BorderThickness="1" />

                        <Rectangle Height="1" VerticalAlignment="Top" Fill="#6AEFFF" />
                        <Rectangle Width="42" Height="1.4" Margin="18,18,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#A0F6FF" />
                        <Rectangle Width="1.4" Height="18" Margin="18,18,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#A0F6FF" />
                        <Rectangle Width="42" Height="1.4" Margin="0,18,18,0" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="#58D9F3" />
                        <Rectangle Width="1.4" Height="18" Margin="0,18,18,0" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="#58D9F3" />
                        <Rectangle Width="42" Height="1.4" Margin="18,0,0,18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Fill="#58D9F3" />
                        <Rectangle Width="1.4" Height="18" Margin="18,0,0,18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Fill="#58D9F3" />
                        <Rectangle Width="42" Height="1.4" Margin="0,0,18,18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#A0F6FF" />
                        <Rectangle Width="1.4" Height="18" Margin="0,0,18,18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#A0F6FF" />

                        <Grid Margin="30,28,30,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="GARAGE COMMAND DECK" Style="{StaticResource HudEyebrowTextStyle}" />

                            <TextBlock
                                Grid.Row="1"
                                Margin="0,14,0,0"
                                Text="CANvision Native Garage"
                                Style="{StaticResource HudTitleTextStyle}" />

                            <ui:TypewriterTextBlock
                                Grid.Row="2"
                                Margin="0,18,0,0"
                                Text="{Binding LaunchGuidance}"
                                CharacterInterval="20" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Button
            x:Name="EnterSystemButton"
            Margin="0,0,0,28"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Opacity="0"
            Style="{StaticResource HudHeroCapsuleButtonStyle}"
            Command="{Binding DataContext.NavigationService.EnterSystemCommand, RelativeSource={RelativeSource AncestorType=Window}}">
            <Button.RenderTransform>
                <TranslateTransform Y="16" />
            </Button.RenderTransform>

            <Button.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="EnterSystemButton"
                                Storyboard.TargetProperty="Opacity"
                                From="0"
                                To="1"
                                BeginTime="0:0:0.12"
                                Duration="0:0:0.42" />
                            <DoubleAnimation
                                Storyboard.TargetName="EnterSystemButton"
                                Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                From="16"
                                To="0"
                                BeginTime="0:0:0.12"
                                Duration="0:0:0.42">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>

            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="Dive In" />
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Consolas"
                    FontSize="17"
                    Text=">" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
