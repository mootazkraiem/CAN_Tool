<UserControl
    x:Class="CANvision.Native.UI.PreviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Focusable="True"
    PreviewKeyDown="OnPreviewKeyDown"
    Loaded="OnLoaded">
    
    <Grid Background="#080d0d">
        <!-- Radial Glow -->
        <Ellipse HorizontalAlignment="Center" VerticalAlignment="Center" Width="1000" Height="1000" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#1200FFFF" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Top-Left Back To Main Screen -->
        <Button Command="{Binding DataContext.NavigateHomeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="16,64,0,0"
                Style="{StaticResource HudActionButtonStyle}"
                Panel.ZIndex="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&lt;" FontFamily="Consolas" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="BACK TO LANDING" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

        <!-- Right Side 6 Interactive Dots -->
        <ItemsControl
            Panel.ZIndex="12"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,220,0"
            ItemsSource="{Binding Dots}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="0,0,0,12" Background="Transparent" BorderThickness="0" ToolTip="{Binding Title}"
                            Command="{Binding DataContext.ChangePreviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding Key}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid Width="10" Height="10" Background="Transparent" Cursor="Hand">
                                    <Path Data="M 5,0 L 10,5 L 5,10 L 0,5 Z" Stroke="#4D00FFFF" StrokeThickness="1" x:Name="DotPath" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="DotPath" Property="Fill" Value="#00ffff" />
                                        <Setter TargetName="DotPath" Property="StrokeThickness" Value="0" />
                                        <Setter TargetName="DotPath" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#00ffff" BlurRadius="8" Opacity="0.8" ShadowDepth="0" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="DotPath" Property="Stroke" Value="#B300FFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Center Card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="500" Padding="48,40" 
                Background="#EB040C0C" BorderBrush="#3300FFFF" BorderThickness="1" CornerRadius="4">
            <Grid>
                <!-- Bracket Top-Left -->
                <Path Data="M 0,32 L 0,0 L 32,0" Stroke="#5900FFFF" StrokeThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-48,-40,0,0" IsHitTestVisible="False"/>
                <!-- Bracket Bottom-Right -->
                <Path Data="M 32,0 L 32,32 L 0,32" Stroke="#5900FFFF" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-48,-40" IsHitTestVisible="False"/>

                <StackPanel>
                    <TextBlock Text="{Binding DisplayLabel}" Foreground="#CC00FFFF" FontSize="10" FontFamily="Space Grotesk"
                               HorizontalAlignment="Left" TextAlignment="Left" Margin="0,0,0,20" />

                    <TextBlock Text="{Binding DisplayTitle}" Foreground="#ffffff" FontSize="52" FontWeight="Bold" FontFamily="Space Grotesk"
                               HorizontalAlignment="Left" TextAlignment="Left" Margin="0,0,0,24">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00ffff" BlurRadius="20" Opacity="0.4" ShadowDepth="0" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock Text="{Binding DisplayDescription}" Foreground="#8a9a9a" FontSize="13" FontFamily="Manrope" TextWrapping="Wrap"
                               TextAlignment="Left" HorizontalAlignment="Left" MaxWidth="400" LineHeight="23.4" Margin="0,0,0,20" />

                    <TextBlock Text="{Binding DisplayStatus}" Foreground="#5900FFFF" FontSize="10" FontFamily="Manrope"
                               HorizontalAlignment="Left" TextAlignment="Left" Margin="0,0,0,20" />

                    <Button Command="{Binding LaunchSectionCommand}" 
                            HorizontalAlignment="Stretch"
                            Padding="14" 
                            Content="{Binding DisplayButtonLabel}"
                            Focusable="False">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource HudActionButtonStyle}">
                                <Setter Property="Background" Value="#B3000000" />
                                <Setter Property="BorderBrush" Value="#5900FFFF" />
                                <Setter Property="Foreground" Value="#ffffff" />
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="FontFamily" Value="Space Grotesk" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0F00FFFF" />
                                        <Setter Property="BorderBrush" Value="#B300FFFF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom Status Bar -->
        <Grid VerticalAlignment="Bottom" Margin="16" Height="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Bottom">
                <TextBlock Text="SLOT_8" FontSize="9" Foreground="#4a5568" FontFamily="Manrope" />
                <TextBlock Text="OCY-ALPHA" FontSize="11" Foreground="#a0aec0" FontWeight="Bold" FontFamily="Manrope" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="AUTH STATUS" FontSize="9" Foreground="#4a5568" FontFamily="Manrope" />
                    <TextBlock Text="SECURED ACCESS" FontSize="11" Foreground="#a0aec0" FontWeight="Bold" FontFamily="Manrope" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="PROTOCOL" FontSize="9" Foreground="#4a5568" FontFamily="Manrope" />
                    <TextBlock Text="DIRECT-NEURAL LINK" FontSize="11" Foreground="#a0aec0" FontWeight="Bold" FontFamily="Manrope" />
                </StackPanel>
            </StackPanel>
            
            <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                <TextBlock Text="SYSTEM TIME" FontSize="9" Foreground="#4a5568" FontFamily="Manrope" HorizontalAlignment="Right" />
                <TextBlock Text="{Binding CurrentTimeText}" FontSize="11" Foreground="#a0aec0" FontWeight="Bold" FontFamily="Manrope" HorizontalAlignment="Right" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
