<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="HudAccentBrush" Color="#69EDFF" />
    <SolidColorBrush x:Key="HudAccentStrongBrush" Color="#E6FCFF" />
    <SolidColorBrush x:Key="HudAccentSoftBrush" Color="#301AC0DA" />
    <SolidColorBrush x:Key="HudSurfaceBrush" Color="#B10A131C" />
    <SolidColorBrush x:Key="HudSurfaceStrongBrush" Color="#D40A1721" />
    <SolidColorBrush x:Key="HudSurfaceDimBrush" Color="#9A09131B" />
    <SolidColorBrush x:Key="HudBorderBrush" Color="#564CCDEB" />
    <SolidColorBrush x:Key="HudBorderStrongBrush" Color="#93C7F8FF" />
    <SolidColorBrush x:Key="HudTitleBrush" Color="#F3FBFF" />
    <SolidColorBrush x:Key="HudBodyBrush" Color="#B4CDD7" />
    <SolidColorBrush x:Key="HudMutedBrush" Color="#79919D" />
    <SolidColorBrush x:Key="HudCriticalBrush" Color="#FF8C8C" />
    <SolidColorBrush x:Key="HudWatchBrush" Color="#FFE38A" />
    <SolidColorBrush x:Key="HudNominalBrush" Color="#86F4D0" />

    <Style x:Key="HudCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HudSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HudBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="22" />
    </Style>

    <Style x:Key="HudHeroCardStyle" TargetType="Border" BasedOn="{StaticResource HudCardStyle}">
        <Setter Property="Background" Value="{StaticResource HudSurfaceStrongBrush}" />
        <Setter Property="Padding" Value="26" />
    </Style>

    <Style x:Key="HudCommandCardStyle" TargetType="Border" BasedOn="{StaticResource HudHeroCardStyle}">
        <Setter Property="Background" Value="#D1081620" />
        <Setter Property="BorderBrush" Value="{StaticResource HudBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1.1" />
        <Setter Property="CornerRadius" Value="26" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                    BlurRadius="24"
                    ShadowDepth="0"
                    Color="#1E05D9F5"
                    Opacity="0.88" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HudSystemShellStyle" TargetType="Border" BasedOn="{StaticResource HudCommandCardStyle}">
        <Setter Property="Background" Value="#D0081219" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="28" />
    </Style>

    <Style x:Key="HudDataPanelStyle" TargetType="Border" BasedOn="{StaticResource HudCardStyle}">
        <Setter Property="Background" Value="{StaticResource HudSurfaceDimBrush}" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="HudMetricTileStyle" TargetType="Border" BasedOn="{StaticResource HudDataPanelStyle}">
        <Setter Property="MinHeight" Value="126" />
    </Style>

    <Style x:Key="HudEyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudAccentBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudTitleBrush}" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudSectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudTitleBrush}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudBodyTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudBodyBrush}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudMutedTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudMutedBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudMetricValueTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudTitleBrush}" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Bahnschrift" />
    </Style>

    <Style x:Key="HudMetricLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudMutedBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HudBadgeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#1200E6FF" />
        <Setter Property="BorderBrush" Value="{StaticResource HudAccentSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style x:Key="HudStatusCardStyle" TargetType="Border" BasedOn="{StaticResource HudDataPanelStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="WATCH">
                <Setter Property="BorderBrush" Value="{StaticResource HudWatchBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="CRITICAL">
                <Setter Property="BorderBrush" Value="{StaticResource HudCriticalBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="NOMINAL">
                <Setter Property="BorderBrush" Value="{StaticResource HudNominalBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
