<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="HudCommandButtonBaseStyle" TargetType="Button">
        <Setter Property="Background" Value="#73000000" />
        <Setter Property="BorderBrush" Value="#5900FFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource HudTitleBrush}" />
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid SnapsToDevicePixels="True">
                        <Border
                            x:Name="Glow"
                            CornerRadius="8"
                            BorderBrush="#9900FFFF"
                            BorderThickness="1"
                            Opacity="0">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="16"
                                    ShadowDepth="0"
                                    Color="#4D00FFFF"
                                    Opacity="1" />
                            </Border.Effect>
                        </Border>

                        <Border
                            x:Name="Shell"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <Grid ClipToBounds="True">
                                <Border
                                    Margin="1"
                                    CornerRadius="7"
                                    Background="#12233140"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1" />

                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Shell" Property="Opacity" Value="0.44" />
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Shell" Property="Background" Value="#1400FFFF" />
                            <Setter TargetName="Shell" Property="BorderBrush" Value="#9900FFFF" />
                            <Setter TargetName="Glow" Property="Opacity" Value="1" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Shell" Property="Background" Value="#1E00FFFF" />
                            <Setter TargetName="Shell" Property="BorderBrush" Value="#9900FFFF" />
                            <Setter TargetName="Glow" Property="Opacity" Value="0.72" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Shell" Property="BorderBrush" Value="#9900FFFF" />
                            <Setter TargetName="Glow" Property="Opacity" Value="0.82" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HudActionButtonStyle" TargetType="Button" BasedOn="{StaticResource HudCommandButtonBaseStyle}">
        <Setter Property="MinWidth" Value="196" />
        <Setter Property="MinHeight" Value="52" />
    </Style>

    <Style x:Key="HudNavButtonStyle" TargetType="Button" BasedOn="{StaticResource HudCommandButtonBaseStyle}">
        <Setter Property="MinWidth" Value="144" />
        <Setter Property="MinHeight" Value="44" />
    </Style>

    <Style x:Key="HudNavCapsuleButtonStyle" TargetType="Button" BasedOn="{StaticResource HudNavButtonStyle}" />

    <Style x:Key="HudHeroButtonStyle" TargetType="Button" BasedOn="{StaticResource HudCommandButtonBaseStyle}">
        <Setter Property="MinWidth" Value="234" />
        <Setter Property="MinHeight" Value="48" />
    </Style>

    <Style x:Key="HudHeroCapsuleButtonStyle" TargetType="Button" BasedOn="{StaticResource HudHeroButtonStyle}" />

    <Style x:Key="HudLaunchTileButtonStyle" TargetType="Button" BasedOn="{StaticResource HudCommandButtonBaseStyle}">
        <Setter Property="MinHeight" Value="134" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="HudTileButtonStyle" TargetType="Button" BasedOn="{StaticResource HudLaunchTileButtonStyle}" />
</ResourceDictionary>
