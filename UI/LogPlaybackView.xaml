<UserControl
    x:Class="CANvision.Native.UI.LogPlaybackView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:CANvision.Native.ViewModels">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://siteoforigin:,,,/assets/6k+-D+copy+-+High+Contrast.webp" Stretch="UniformToFill" Opacity="0.28" />
        </Grid.Background>
        <Rectangle Fill="#E0080C0F" />

        <Grid Margin="24,20,24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Grid.Row="1" Margin="0,12,16,0" Padding="10" Background="#A80A0F11" BorderBrush="#253A41" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock Foreground="#6A909A" FontFamily="Consolas" FontSize="10" Text="SESSION LIST" />
                        <TextBlock DockPanel.Dock="Right" Foreground="#00EFFF" FontFamily="Consolas" FontSize="10" Text="+" />
                    </DockPanel>

                    <ItemsControl Grid.Row="1" Margin="0,10,0,10" ItemsSource="{Binding Sessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PlaybackSessionItem}">
                                <Border Margin="0,0,0,8" Padding="10" Background="#7A0A0E10" BorderBrush="#1F30363C" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Foreground="#DFF2F6" FontFamily="Consolas" FontSize="11" Text="{Binding FileName}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="#6A8C95" FontFamily="Consolas" FontSize="9" Text="{Binding Date}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Width="120" Margin="0,0,8,0" Style="{StaticResource HudActionButtonStyle}" Content="IMPORT SESSION" />
                        <Button Width="70" Style="{StaticResource HudActionButtonStyle}" Content="ADD" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <ItemsControl ItemsSource="{Binding PlaybackTabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,8,0" Padding="12,6" Command="{Binding DataContext.SelectPlaybackTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource HudActionButtonStyle}">
                                        <Setter Property="Background" Value="#8A0A0E10" />
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="10" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Border Grid.Column="1" Grid.Row="1" Padding="16" Background="#B1090E11" BorderBrush="#263B43" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="120" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock Foreground="#E6F6F9" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="34" FontWeight="Bold" Text="{Binding LoadedFileName}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Foreground="#00ECFF" FontFamily="Consolas" FontSize="18" Text="{Binding SessionDurationText}" />
                            <TextBlock Margin="16,0,0,0" Foreground="#67A0AC" FontFamily="Consolas" FontSize="10" Text="READY" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1" Margin="0,12,0,10" Background="#86080B0D" BorderBrush="#1F31383E" BorderThickness="1">
                        <ItemsControl ItemsSource="{Binding EventRows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="18" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PlaybackEventItem}">
                                    <Grid>
                                        <Rectangle Width="3" Height="48" VerticalAlignment="Center" Fill="#00EAFF" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Width="44" Margin="0,0,8,0" Style="{StaticResource HudActionButtonStyle}" Content="|&lt;" />
                        <Button Width="56" Margin="0,0,8,0" Style="{StaticResource HudActionButtonStyle}" Content="▶" />
                        <Button Width="44" Margin="0,0,8,0" Style="{StaticResource HudActionButtonStyle}" Content="||" />
                        <Button Width="44" Style="{StaticResource HudActionButtonStyle}" Content="■" />
                        <TextBlock Margin="24,0,8,0" VerticalAlignment="Center" Foreground="#6A9099" FontFamily="Consolas" FontSize="10" Text="REPLAY SPEED" />
                        <ItemsControl ItemsSource="{Binding SpeedOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,6,0" Padding="8,4" Command="{Binding DataContext.SelectReplaySpeedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource HudActionButtonStyle}">
                                                <Setter Property="Background" Value="#8A0A0E10" />
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="10" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <UniformGrid Grid.Row="3" Columns="4">
                        <Border Margin="0,0,8,0" Padding="8" Background="#7A0A0E10" BorderBrush="#1F30363C" BorderThickness="1"><StackPanel><TextBlock Foreground="#6C929D" FontFamily="Consolas" FontSize="9" Text="ENGINE TEMP" /><TextBlock Margin="0,5,0,0" Foreground="#E6F7FA" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="22" Text="{Binding TemperatureText}" /></StackPanel></Border>
                        <Border Margin="0,0,8,0" Padding="8" Background="#7A0A0E10" BorderBrush="#1F30363C" BorderThickness="1"><StackPanel><TextBlock Foreground="#6C929D" FontFamily="Consolas" FontSize="9" Text="BUS LOAD" /><TextBlock Margin="0,5,0,0" Foreground="#E6F7FA" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="22" Text="{Binding BusLoadText}" /></StackPanel></Border>
                        <Border Margin="0,0,8,0" Padding="8" Background="#7A0A0E10" BorderBrush="#1F30363C" BorderThickness="1"><StackPanel><TextBlock Foreground="#6C929D" FontFamily="Consolas" FontSize="9" Text="MOTOR RPM" /><TextBlock Margin="0,5,0,0" Foreground="#00EEFF" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="22" Text="{Binding SpeedText}" /></StackPanel></Border>
                        <Border Padding="8" Background="#7A0A0E10" BorderBrush="#1F30363C" BorderThickness="1"><StackPanel><TextBlock Foreground="#6C929D" FontFamily="Consolas" FontSize="9" Text="PACK VOLTAGE" /><TextBlock Margin="0,5,0,0" Foreground="#E6F7FA" FontFamily="{StaticResource HeadlineFontFamily}" FontSize="22" Text="{Binding VoltageText}" /></StackPanel></Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Margin="0,12,0,0" Padding="8" Background="#71080C0E" BorderBrush="#1E2F363C" BorderThickness="1">
                <TextBlock Foreground="#6A8D96" FontFamily="Consolas" FontSize="9" Text="SYSTEM_READY: SESSION_DATA_BUFFER ACTIVE | REFRESH {Binding RefreshIntervalText} | SOURCE {Binding SourceText}" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
