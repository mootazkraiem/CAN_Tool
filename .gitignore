# GENERATED CSV EXPORTS
# =========================
backend/ml/**/*.csv

# KEEP TRAINING / RAW DATASETS
!backend/ml/data/**/*.csv
!backend/ml/assets/**/*.csv
!backend/ml/training/**/*.csv

# =========================
# GENERATED JSON REPORTS
# =========================
backend/ml/**/*.json
backend/ml/**/*.jsonl

# KEEP IMPORTANT CONFIG JSON
!backend/ml/config/**/*.json

