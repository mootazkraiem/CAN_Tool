<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>HelixToolkit.SharpDX.Assimp</id>
    <version>2.27.3</version>
    <title>Assimp Import/Export for HelixToolkit.SharpDX Libraries</title>
    <authors>Lunci</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>helixtoolkit.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/helix-toolkit/helix-toolkit</projectUrl>
    <description>Provides Assimp Import/Export for HelixToolkit.SharpDX.</description>
    <tags>netstandard netcore Wpf UWP SharpDX 3D DirectX Assimp</tags>
    <dependencies>
      <group targetFramework=".NETFramework4.6.2">
        <dependency id="HelixToolkit.Wpf.SharpDX" version="[2.27.3]" />
        <dependency id="AssimpNet" version="5.0.0-beta1" />
        <dependency id="SharpDX" version="4.2.0" />
        <dependency id="SharpDX.Direct3D11" version="4.2.0" />
        <dependency id="SharpDX.Mathematics" version="4.2.0" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="6.0.0" />
      </group>
      <group targetFramework="UAP10.0">
        <dependency id="Microsoft.NETCore.UniversalWindowsPlatform" version="6.1.7" exclude="Build,Analyzers" />
        <dependency id="HelixToolkit.UWP" version="[2.27.3]" />
        <dependency id="AssimpNet" version="5.0.0-beta1" />
        <dependency id="SharpDX" version="4.2.0" />
        <dependency id="SharpDX.Direct3D11" version="4.2.0" />
        <dependency id="SharpDX.Mathematics" version="4.2.0" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="6.0.0" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="HelixToolkit.SharpDX.Core" version="[2.27.3]" />
        <dependency id="AssimpNet" version="5.0.0-beta1" />
        <dependency id="SharpDX" version="4.2.0" />
        <dependency id="SharpDX.Direct3D11" version="4.2.0" />
        <dependency id="SharpDX.Mathematics" version="4.2.0" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="6.0.0" />
      </group>
    </dependencies>
  </metadata>
</package>