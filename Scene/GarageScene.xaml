<UserControl
    x:Class="CANvision.Native.Scene.GarageScene"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:hx="clr-namespace:HelixToolkit.Wpf.SharpDX;assembly=HelixToolkit.Wpf.SharpDX">
    <Grid ClipToBounds="False">
        <Grid.Background>
            <ImageBrush ImageSource="../assets/3ef5854c-549e-4311-ad07-15c89e0471bd.png" Stretch="UniformToFill" />
        </Grid.Background>
        <hx:Viewport3DX
            x:Name="Viewport"
            Panel.ZIndex="1"
            Background="Transparent"
            BackgroundColor="#00000000"
            CameraMode="Inspect"
            ClipToBounds="False"
            EnableSwapChainRendering="False"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            IsHitTestVisible="True"
            Margin="0"
            ShowCoordinateSystem="False"
            ShowViewCube="False"
            ShowFrameRate="False"
            UseDefaultGestures="False"
            ZoomExtentsWhenLoaded="False">
            <hx:AmbientLight3D Color="#808890" />
            <hx:DirectionalLight3D Color="#FFFFFF" Direction="-1.25,-1.0,-0.65" />
            <hx:DirectionalLight3D Color="#F5F5F5" Direction="0.85,-0.42,0.95" />
            <hx:SceneNodeGroupModel3D x:Name="CarNodeGroup" />
        </hx:Viewport3DX>
    </Grid>
</UserControl>
